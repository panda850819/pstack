#!/usr/bin/env bash
# pstack setup — install skills and commands into Claude Code
set -euo pipefail

PSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="${HOME}/.claude/skills"
COMMANDS_DIR="${HOME}/.claude/commands"

echo "pstack setup"
echo "============"
echo ""

# Create directories if needed
mkdir -p "$SKILLS_DIR"
mkdir -p "$COMMANDS_DIR"

# Install skills as symlinks
echo "Installing skills..."
for skill_dir in "$PSTACK_DIR"/skills/*/; do
    skill_name=$(basename "$skill_dir")
    link_name="ps-${skill_name}"
    target="$SKILLS_DIR/$link_name"

    if [ -L "$target" ]; then
        rm "$target"
    fi

    ln -sf "$skill_dir" "$target"
    echo "  $link_name -> $(basename "$skill_dir")"
done

# Install commands
echo "Installing commands..."
for cmd_file in "$PSTACK_DIR"/commands/*.md; do
    cmd_name=$(basename "$cmd_file" .md)
    link_name="ps-${cmd_name}.md"
    target="$COMMANDS_DIR/$link_name"

    if [ -L "$target" ]; then
        rm "$target"
    fi

    ln -sf "$cmd_file" "$target"
    echo "  /ps-$cmd_name"
done

echo ""
echo "Done! Installed:"
echo "  - $(ls -d "$PSTACK_DIR"/skills/*/ | wc -l | tr -d ' ') skills"
echo "  - $(ls "$PSTACK_DIR"/commands/*.md | wc -l | tr -d ' ') commands"
echo ""
echo "Next steps:"
echo "  1. Open Claude Code in your project"
echo "  2. Run /ps-init to configure pstack for this project"
echo "  3. Start coding, then run /ps-review"
echo ""
echo "To uninstall:"
echo "  $0 --uninstall"
